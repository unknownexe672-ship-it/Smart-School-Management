# ── SmartSchool Configuration ────────────────────────────────────────────────
# Copy this file to config.env and fill in your values.
# Place config.env in the same folder as this example, or in:
#   Windows: %APPDATA%\SmartSchool\config.env
#
# The app will still launch in Demo Mode if DATABASE_URL is absent or
# if the database cannot be reached (e.g. no internet connection).
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Replit database or any PostgreSQL server)
# Example: postgres://user:password@host:5432/database?sslmode=require
DATABASE_URL=

# DeepSeek API key — required for Amira AI chat feature
DEEPSEEK_API_KEY=

# Session secret — used to sign cookies (change this to a long random string)
SESSION_SECRET=change-me-please-use-a-long-random-string
